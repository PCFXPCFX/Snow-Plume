---
import TopBar from "../components/TopBar.astro";
// 共享布局：所有页面共用的 HTML 骨架
export interface Props {
  title: string;
  description?: string;
  color?: string;
}

const { title, description = "LoveLive! 系列粉丝站", color = "#FF6B8A" } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content={color} />
    <title>{title}</title>
    <!-- Google Font: Noto Sans SC -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;700;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen text-gray-800 font-sans antialiased pt-16 bg-[#f5f5f7]">
    <TopBar />
    <slot />
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
    font-size: 90%;
  }
</style>

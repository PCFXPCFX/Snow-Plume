<!--
  MemberColors — 成员应援色选择器
  点击成员色点切换页面主色调，带柔和环状高亮
-->
---
const { members } = Astro.props;
---

<div class="inline-flex items-center gap-2.5 flex-wrap justify-center">
  <span class="text-xs text-white/50 mr-1 tracking-wide">应援色</span>
  {members.map((member) => (
    <button
      type="button"
      class="color-dot w-7 h-7 rounded-full ring-1 ring-white/20 hover:ring-white/40
             hover:scale-125 transition-all duration-300 shadow-sm"
      style={`background-color: ${member.color}`}
      data-color={member.color}
      title={member.name}
      aria-label={`切换为${member.name}的应援色`}
    ></button>
  ))}
</div>

<script>
  // 点击色点 → 切换页面主色调
  document.querySelectorAll(".color-dot").forEach(function(dot) {
    dot.addEventListener("click", function() {
      const color = dot.getAttribute("data-color");
      document.documentElement.style.setProperty("--accent", color);
      document.querySelectorAll(".color-dot").forEach(function(d) {
        d.classList.remove("ring-2", "ring-white", "ring-offset-1", "ring-offset-black/10", "scale-125");
        d.classList.add("ring-1", "ring-white/20");
      });
      dot.classList.remove("ring-1", "ring-white/20");
      dot.classList.add("ring-2", "ring-white", "ring-offset-1", "ring-offset-black/10", "scale-125");
    });
  });
</script>

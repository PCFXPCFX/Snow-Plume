<!--
  BlogList — 博客文章列表
  按 group 过滤，显示标题、日期、摘要
-->
---
import { getCollection } from "astro:content";

export interface Props {
  group: string;       // 团体标识：lovelive / 缪 / 水 / 虹 / 星 / 莲
  max?: number;         // 最多显示几篇
}

const { group, max = 5 } = Astro.props;

// 获取该团体的博客文章，按日期倒序
const allPosts = await getCollection("blog");
const posts = allPosts
  .filter((p) => p.data.group === group)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, max);
---

<div class="space-y-3">
  {posts.length === 0 ? (
    <div class="bg-white rounded-2xl p-10 border border-gray-100/80 text-center">
      <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-gray-50 flex items-center justify-center">
        <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
            d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
        </svg>
      </div>
      <p class="text-sm text-gray-400 mb-1">还没有感想</p>
      <p class="text-xs text-gray-300">偶尔会写一些，不急～</p>
    </div>
  ) : (
    posts.map((post) => (
      <a
        href={`/blog/${post.slug}/`}
        class="group/post block bg-white rounded-2xl p-6 shadow-sm border border-gray-100/80
               hover:shadow-md hover:-translate-y-0.5 transition-all duration-300"
      >
        <div class="flex items-start justify-between gap-4">
          <div class="flex-1 min-w-0">
            <h3 class="text-base font-semibold text-gray-800 mb-2 group-hover/post:text-gray-900 transition-colors">
              {post.data.title}
            </h3>
            <div class="w-6 h-0.5 rounded-full mb-3 transition-colors duration-500" style="background: var(--accent, #ec4899)"></div>
            {post.data.excerpt && (
              <p class="text-sm text-gray-500 line-clamp-2 mb-3 leading-relaxed">{post.data.excerpt}</p>
            )}
            <time class="text-xs text-gray-400" datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString("zh-CN", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </time>
          </div>
          <!-- 右侧箭头 -->
          <span class="text-gray-200 group-hover/post:text-gray-400 transition-all duration-300 mt-2 shrink-0 group-hover/post:translate-x-0.5">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </span>
        </div>
      </a>
    ))
  )}
</div>

<!--
  GroupPage — 各团体专属页面
  封面图 → 上滑 → Hero 信息区 → 成员应援色 → 代表曲 → 博客 → 照片墙
-->
---
import CoverSection from "./CoverSection.astro";
import BlogList from "./BlogList.astro";
import MemberColors from "./MemberColors.astro";
import PhotoWall from "./PhotoWall.astro";

const group = Astro.props.group;
---

<div>
  <!-- 全屏封面 + 上滑提示 -->
  <CoverSection group={group} />

  <!-- 页面主体 -->
  <div id={`group-content-${group.subdomain}`} class="min-h-screen scroll-mt-16">
    <!-- Hero 信息区 -->
    <div class="relative overflow-hidden transition-colors duration-700" style="background: var(--accent)">
      <!-- 背景装饰 -->
      <div class="absolute inset-0 opacity-[0.07]">
        <div class="absolute -top-20 -left-20 w-80 h-80 rounded-full bg-white blur-3xl"></div>
        <div class="absolute -bottom-20 -right-20 w-96 h-96 rounded-full bg-black blur-3xl"></div>
      </div>

      <div class="relative max-w-4xl mx-auto px-6 py-20 md:py-28 text-center text-white">
        <p class="text-base md:text-lg font-light mb-3 opacity-70 tracking-wider">
          {group.fullName}
        </p>
        <h1 class="text-6xl md:text-7xl font-black mb-5 tracking-tight">
          {group.name}
        </h1>
        <p class="text-2xl md:text-3xl font-light mb-10 tracking-wide">
          「{group.description}」
        </p>

        <!-- 成员应援色选择器 -->
        <MemberColors members={group.members} />

        <!-- 标签 -->
        <div class="flex justify-center gap-3 flex-wrap mt-10">
          <span class="px-5 py-2 rounded-full bg-white/15 backdrop-blur-sm text-sm font-medium tracking-wide">
            {group.members.length} 位成员
          </span>
          <span class="px-5 py-2 rounded-full bg-white/15 backdrop-blur-sm text-sm font-medium tracking-wide">
            {group.years}
          </span>
        </div>
      </div>

      <!-- 底部过渡 -->
      <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-[#f5f5f7] to-transparent"></div>
    </div>

    <!-- 内容区 -->
    <div class="max-w-4xl mx-auto px-6 py-20 space-y-24">

      <!-- 莲之空专属：各期成员展示 -->
      {group.periods && (
        <section>
          <div class="mb-8">
            <p class="text-xs text-gray-400 tracking-[0.2em] mb-2 uppercase">Members</p>
            <h2 class="text-3xl font-bold text-gray-800">各期成员</h2>
            <div class="mt-3 w-12 h-0.5 rounded-full transition-colors duration-500" style="background: var(--accent)"></div>
          </div>
          <div class="space-y-4">
            {group.periods.map((period) => (
              <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100/80 hover:shadow-md transition-shadow duration-300">
                <div class="flex items-center gap-3 mb-5">
                  <h3 class="text-lg font-bold text-gray-800">{period.name}</h3>
                  <span class="text-xs text-gray-400">{period.years}</span>
                  <span class={`px-2.5 py-0.5 rounded-full text-xs font-medium ${
                    period.status === "已毕业"
                      ? "bg-gray-100 text-gray-400"
                      : "bg-emerald-50 text-emerald-600"
                  }`}>
                    {period.status}
                  </span>
                </div>
                <div class="flex flex-wrap gap-2.5">
                  {period.members.map((m) => (
                    <div class="flex items-center gap-2 bg-gray-50 rounded-xl px-4 py-2.5 hover:bg-gray-100 transition-colors">
                      <span class="w-2.5 h-2.5 rounded-full shrink-0 ring-1 ring-black/5" style={`background: ${m.color}`}></span>
                      <span class="text-sm text-gray-700 font-medium">{m.name}</span>
                      <span class="text-xs text-gray-400">{m.unit}</span>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- 代表曲 -->
      <section>
        <div class="mb-8">
          <p class="text-xs text-gray-400 tracking-[0.2em] mb-2 uppercase">Songs</p>
          <h2 class="text-3xl font-bold text-gray-800">我最喜爱的歌曲</h2>
          <div class="mt-3 w-12 h-0.5 rounded-full transition-colors duration-500" style="background: var(--accent)"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {group.songs.map((song, i) => {
            const name = typeof song === "string" ? song : song.name;
            const url = typeof song === "object" ? song.url : undefined;
            const isExternal = url && (url.startsWith("http://") || url.startsWith("https://"));

            const cardContent = (
              <div class="group/song relative bg-white rounded-2xl p-6 shadow-sm border border-gray-100/80
                          hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300 overflow-hidden
                          h-full">
                <!-- 序号水印 -->
                <span class="absolute -bottom-4 -right-2 text-8xl font-black text-gray-50 select-none pointer-events-none">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <div class="relative">
                  <!-- 小装饰线 -->
                  <div class="w-8 h-0.5 rounded-full mb-3 transition-colors duration-500" style="background: var(--accent)"></div>
                  <div class="text-lg font-semibold text-gray-800 group-hover/song:text-gray-900 transition-colors">
                    {name}
                  </div>
                  {url && (
                    <div class="mt-2 flex items-center gap-1 text-xs text-gray-400 group-hover/song:text-gray-500 transition-colors">
                      {isExternal ? (
                        <>
                          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                          </svg>
                          <span>B站观看</span>
                        </>
                      ) : (
                        <>
                          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                          </svg>
                          <span>阅读博文</span>
                        </>
                      )}
                    </div>
                  )}
                </div>
              </div>
            );

            return url ? (
              <a href={url} target={isExternal ? "_blank" : undefined} rel={isExternal ? "noopener noreferrer" : undefined}>
                {cardContent}
              </a>
            ) : (
              cardContent
            );
          })}
        </div>
      </section>

      <!-- 博客区 -->
      <section>
        <div class="mb-8">
          <p class="text-xs text-gray-400 tracking-[0.2em] mb-2 uppercase">Notes</p>
          <h2 class="text-3xl font-bold text-gray-800">一些感想</h2>
          <div class="mt-3 w-12 h-0.5 rounded-full transition-colors duration-500" style="background: var(--accent)"></div>
        </div>
        <BlogList group={group.subdomain} />
      </section>

      <!-- 照片墙 -->
      <section>
        <div class="mb-8">
          <p class="text-xs text-gray-400 tracking-[0.2em] mb-2 uppercase">Gallery</p>
          <h2 class="text-3xl font-bold text-gray-800">照片墙</h2>
          <div class="mt-3 w-12 h-0.5 rounded-full transition-colors duration-500" style="background: var(--accent)"></div>
        </div>
        <PhotoWall group={group} />
      </section>

      <!-- 返回导航 -->
      <div class="text-center pt-8 border-t border-gray-100">
        <a
          href="https://lovelive.example.com"
          data-back-to-hub
          class="inline-flex items-center gap-2 px-6 py-3 rounded-full
                 bg-white border border-gray-200 text-gray-500
                 hover:border-gray-300 hover:text-gray-700 hover:shadow-sm
                 transition-all duration-300 text-sm"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
          </svg>
          返回导航页
        </a>
      </div>
    </div>
  </div>
</div>
